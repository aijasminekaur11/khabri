# Telegram Bot Configuration
# Copy this file to .env and fill in your actual values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram Chat ID(s) - supports multiple IDs (comma-separated)
# Single user: TELEGRAM_CHAT_ID=123456789
# Multiple users: TELEGRAM_CHAT_ID=123456789,987654321,555555555
TELEGRAM_CHAT_ID=123456789

# Optional: Authorized Chat IDs for bot commands (comma-separated)
# If not set, bot accepts commands from anyone
# TELEGRAM_AUTHORIZED_IDS=123456789,987654321
TELEGRAM_AUTHORIZED_IDS=123456789

# GitHub Personal Access Token
# NOTE: Use GH_TOKEN (NOT GITHUB_TOKEN - that prefix is reserved by GitHub)
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Repository (owner/repo format)
GITHUB_REPO=aijasminekaur11/khabri
