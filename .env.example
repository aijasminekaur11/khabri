# =============================================================================
# Khabri - News Intelligence System
# Environment Variables Template
# =============================================================================
#
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in your actual credentials
# 3. Never commit .env to git (it's in .gitignore)
#
# =============================================================================

# =============================================================================
# TELEGRAM CONFIGURATION
# =============================================================================
# How to get these:
# 1. Create a bot: Message @BotFather on Telegram, send /newbot
# 2. Get token: BotFather will give you the token
# 3. Get chat ID:
#    - Add bot to your group/channel
#    - Send a message in the group
#    - Visit: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    - Find "chat":{"id": YOUR_CHAT_ID}

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# =============================================================================
# EMAIL CONFIGURATION (Gmail Example)
# =============================================================================
# How to set up Gmail:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate an "App Password" for "Mail"
# 4. Use that app password below (NOT your regular Gmail password)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_RECIPIENT=recipient@example.com

# =============================================================================
# OPTIONAL: MULTIPLE RECIPIENTS
# =============================================================================
# Comma-separated list of email recipients
# EMAIL_RECIPIENTS=user1@example.com,user2@example.com,user3@example.com

# =============================================================================
# OPTIONAL: ADVANCED SETTINGS
# =============================================================================
# LOG_LEVEL=INFO
# TIMEZONE=Asia/Kolkata
# CHECK_INTERVAL_SECONDS=60
